FROM golang:1.26-alpine

# Install Air for hot reload
RUN go install github.com/air-verse/air@latest

WORKDIR /backend

# Copy local replace directive targets before go mod download —
# go.mod references auth-service and go-grpc-crud via replace directives
# pointing to relative paths, which must exist when Docker resolves them.
COPY services/ /services/

# Copy go mod files
COPY backend-core/go.mod backend-core/go.sum* ./

# Download dependencies
RUN go mod download

# Copy backend source code
COPY backend-core/ .

# Expose port
EXPOSE 8080

# Run with Air
CMD ["air"]
